@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<section class="hero-panel text-center">
    <p class="eyebrow">Interstellar Hospitality for Curious Species</p>
    <h1 class="display-3">Sleep inside the neon pulse of the cosmos.</h1>
    <p class="hero-copy">
        Starstay is the booking portal for orbiting villas, bio-luminescent domes, and luxury starships
        curated for humans, xenos, and every traveler in between.
    </p>
    <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href="#">Explore Starports</a>
        <a class="btn btn-outline-light btn-lg" href="#">List Your Starship</a>
    </div>
</section>

<section class="feature-grid">
    <article class="feature-card">
        <span class="feature-kicker">01</span>
        <h2>Alien Ambience</h2>
        <p>Book habitats wrapped in living coral walls, plasma gardens, and aurora-view ceilings.</p>
    </article>
    <article class="feature-card">
        <span class="feature-kicker">02</span>
        <h2>Hyperspace Access</h2>
        <p>Dock beside trade moons, wormhole lounges, and deep-space retreats in a few taps.</p>
    </article>
    <article class="feature-card">
        <span class="feature-kicker">03</span>
        <h2>Safe for Every Species</h2>
        <p>Filter by atmosphere, gravitation, nutrient type, and telepathic quiet hours.</p>
    </article>
</section>
