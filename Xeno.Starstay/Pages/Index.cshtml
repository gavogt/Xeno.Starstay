@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<section class="hero-panel text-center">
    <p class="eyebrow">Interstellar Hospitality for Curious Species</p>
    <h1 class="display-3">Sleep inside the neon pulse of the cosmos.</h1>
    <p class="hero-copy">
        Starstay is the booking portal for orbiting villas, bio-luminescent domes, and luxury starships
        curated for humans, xenos, and every traveler in between.
    </p>
    <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href="#explore-starports">Explore Starports</a>
        <a class="btn btn-outline-light btn-lg" href="#">List Your Starship</a>
    </div>
</section>

<section class="feature-grid">
    <article class="feature-card">
        <span class="feature-kicker">01</span>
        <h2>Alien Ambience</h2>
        <p>Book habitats wrapped in living coral walls, plasma gardens, and aurora-view ceilings.</p>
    </article>
    <article class="feature-card">
        <span class="feature-kicker">02</span>
        <h2>Hyperspace Access</h2>
        <p>Dock beside trade moons, wormhole lounges, and deep-space retreats in a few taps.</p>
    </article>
    <article class="feature-card">
        <span class="feature-kicker">03</span>
        <h2>Safe for Every Species</h2>
        <p>Filter by atmosphere, gravitation, nutrient type, and telepathic quiet hours.</p>
    </article>
</section>

<section class="starports-section" id="explore-starports">
    <div class="section-intro text-center">
        <p class="eyebrow">Explore Starports</p>
        <h2 class="display-5">Ten rooms from the far edge of luxury.</h2>
        <p class="section-copy">
            From coral observatories to magma sanctuaries and translucent biosuites, these starship stays were
            selected for travelers who want their sleep cycle wrapped in something strange, elegant, and unforgettable.
        </p>
    </div>

    <div class="starport-grid">
        <article class="starport-card">
            <img src="~/images/starports/orchid-nebula-nest.png" alt="The Orchid Nebula Nest starship suite" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Drift Lounge</p>
                <h3>The Orchid Nebula Nest</h3>
                <p>A plush circular suite suspended above a glowing hull garden with endless violet starlight.</p>
            </div>
        </article>
        <article class="starport-card">
            <img src="~/images/starports/coral-vault-suite.png" alt="The Coral Vault Suite alien hotel room" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Living Vessel</p>
                <h3>The Coral Vault Suite</h3>
                <p>An organic chamber grown into the ship itself, lined with luminous reef walls and shell-light alcoves.</p>
            </div>
        </article>
        <article class="starport-card">
            <img src="~/images/starports/prism-spine-reserve.png" alt="The Prism Spine Reserve crystal starship room" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Crystal Deck</p>
                <h3>The Prism Spine Reserve</h3>
                <p>A faceted hideaway where mirrored crystal ribs throw neon constellations across the bed canopy.</p>
            </div>
        </article>
        <article class="starport-card">
            <img src="~/images/starports/moonpool-drift-pod.png" alt="The Moonpool Drift Pod futuristic alien suite" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Quiet Orbit</p>
                <h3>The Moonpool Drift Pod</h3>
                <p>A meditative spa pod with reflective water channels and a ringed planet glowing just beyond the glass.</p>
            </div>
        </article>
        <article class="starport-card">
            <img src="~/images/starports/halo-bloom-conservatory.png" alt="The Halo Bloom Conservatory alien greenhouse suite" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Botanical Dome</p>
                <h3>The Halo Bloom Conservatory</h3>
                <p>A dome-wrapped retreat filled with floating orchids, misted chrome, and soft bioluminescent petals.</p>
            </div>
        </article>
        <article class="starport-card">
            <img src="~/images/starports/orbit-oracle-cabin.png" alt="The Orbit Oracle Cabin high-tech starship suite" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Navigator Wing</p>
                <h3>The Orbit Oracle Cabin</h3>
                <p>A glamorous research-cruiser room with holographic walls, angular furniture, and a nebula-side workstation.</p>
            </div>
        </article>
        <article class="starport-card">
            <img src="~/images/starports/empress-rift-atrium.png" alt="The Empress Rift Atrium grand alien royal suite" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Royal Deck</p>
                <h3>The Empress Rift Atrium</h3>
                <p>An opulent grand suite with vaulted arches, elevated sleeping dais, and ceremonial light artifacts.</p>
            </div>
        </article>
        <article class="starport-card">
            <img src="~/images/starports/zenith-gyre-sphere.png" alt="The Zenith Gyre Sphere anti-gravity alien observatory suite" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Zero-G Crown</p>
                <h3>The Zenith Gyre Sphere</h3>
                <p>A transparent orbital capsule where the bed hovers midair beneath rotating light rings and impossible gravity.</p>
            </div>
        </article>
        <article class="starport-card">
            <img src="~/images/starports/ember-crypt-habitat.png" alt="The Ember Crypt Habitat volcanic alien starship room" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Magma Reliquary</p>
                <h3>The Ember Crypt Habitat</h3>
                <p>A carved obsidian sanctuary lit by molten veins and ember pools for guests who prefer their luxury ritualistic.</p>
            </div>
        </article>
        <article class="starport-card">
            <img src="~/images/starports/seraph-tide-biosuite.png" alt="The Seraph Tide Biosuite translucent bioengineered alien room" class="starport-image" />
            <div class="starport-body">
                <p class="starport-label">Oceanic Vessel</p>
                <h3>The Seraph Tide Biosuite</h3>
                <p>A soft living chamber of glowing membranes and drifting tendrils, like sleeping inside a celestial jellyfish.</p>
            </div>
        </article>
    </div>
</section>
