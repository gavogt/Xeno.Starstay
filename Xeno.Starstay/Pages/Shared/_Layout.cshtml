@using Microsoft.AspNetCore.Http
@using Xeno.Starstay.Models
@inject Microsoft.AspNetCore.Identity.SignInManager<ApplicationUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager
@{
    var isSignedIn = SignInManager.IsSignedIn(User);
    var displayName = Context.Session.GetString("DisplayName");

    if (isSignedIn && string.IsNullOrWhiteSpace(displayName))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        displayName = currentUser?.DisplayName ?? currentUser?.UserName ?? User.Identity?.Name;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Xeno.Starstay</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Xeno.Starstay.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm starstay-nav mb-4">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Xeno.Starstay</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                    @if (isSignedIn)
                    {
                        <div class="nav-auth nav-auth-signedin">
                            <span class="user-greeting">Welcome, @displayName</span>
                            <form method="post" asp-page="/Logout" class="logout-form">
                                <button type="submit" class="btn btn-outline-light nav-cta">Logout</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="nav-auth">
                            <a class="nav-link auth-link" asp-area="" asp-page="/Login">Login</a>
                            <a class="btn btn-primary nav-cta" asp-area="" asp-page="/Register">Register</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container page-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            &copy; 2026 - Xeno.Starstay - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
