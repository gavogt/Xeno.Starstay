@page
@model Xeno.Starstay.Pages.StarportsModel
@{
    ViewData["Title"] = "Starports";
}

<section class="traveler-page-shell">
    <div class="traveler-hero">
        <p class="eyebrow">Traveler Deck</p>
        <h1 class="display-5">Browse every live Starstay listing in one orbit.</h1>
        <p class="section-copy">
            Scroll the live marketplace of starship suites, compare atmosphere and gravity profiles,
            and lock in a voyage when the perfect cabin finds you.
        </p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="auth-status @Model.StatusCssClass traveler-status">
            @Model.StatusMessage
        </div>
    }

    @if (User.Identity?.IsAuthenticated == true)
    {
        <section class="traveler-panel">
            <div class="traveler-panel-heading">
                <h2>Your Upcoming Voyages</h2>
                <p>@Model.MyBookings.Count reservation@(Model.MyBookings.Count == 1 ? "" : "s") on the manifest</p>
            </div>

            @if (Model.MyBookings.Count == 0)
            {
                <div class="empty-state">
                    <p>No voyages booked yet. Browse the orbit deck below and reserve your first stay.</p>
                </div>
            }
            else
            {
                <div class="voyage-list">
                    @foreach (var booking in Model.MyBookings)
                    {
                        <article class="voyage-card">
                            <img src="@booking.StarshipListing?.PhotoUrl" alt="@booking.StarshipListing?.VesselName" class="voyage-card-image" />
                            <div class="voyage-card-body">
                                <p class="starport-label">Confirmed Voyage</p>
                                <h3>@booking.StarshipListing?.VesselName</h3>
                                <p class="traveler-location">@booking.StarshipListing?.AlienLocation</p>
                                <div class="voyage-meta-grid">
                                    <div class="host-spec">
                                        <span>Arrival</span>
                                        <strong>@booking.CheckInDate.ToString("MMM d, yyyy")</strong>
                                    </div>
                                    <div class="host-spec">
                                        <span>Departure</span>
                                        <strong>@booking.CheckOutDate.ToString("MMM d, yyyy")</strong>
                                    </div>
                                </div>
                                <div class="host-meta">
                                    <span>@booking.CycleCount cycle@(booking.CycleCount == 1 ? "" : "s") booked</span>
                                    <strong>@booking.TotalNebulaCredits.ToString("0.00") nebula credits</strong>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }

    <section class="traveler-panel">
        <div class="traveler-filter-panel">
            <div class="traveler-panel-heading">
                <h2>Search The Orbit Deck</h2>
                <p>Drill down by starship signal, location, and habitat compatibility.</p>
            </div>

            <form method="get" class="traveler-filter-form">
                <div class="traveler-filter-grid">
                    <div class="traveler-filter-card">
                        <div class="traveler-filter-copy">
                            <p class="traveler-filter-kicker">Signal Search</p>
                            <h3>Global Search</h3>
                            <p>Scan vessel names, hosts, gravity, atmosphere, habitat notes, and amenity language from one field.</p>
                        </div>

                        <div class="auth-field traveler-filter-input-wrap">
                            <input id="SearchTerm" name="SearchTerm" value="@Model.SearchTerm" class="form-control auth-control traveler-filter-input" placeholder="Try: Velora, low-gravity, oxygen, pets, quantum dock..." />
                        </div>
                    </div>

                    <div class="traveler-filter-card">
                        <div class="traveler-filter-copy">
                            <p class="traveler-filter-kicker">Orbit Filter</p>
                            <h3>Location Channel</h3>
                            <p>Focus the marketplace on a single moonbase, ring station, or alien district before layering compatibility filters.</p>
                        </div>

                        <div class="auth-field traveler-filter-input-wrap">
                            <select id="SelectedLocation" name="SelectedLocation" class="form-select auth-control host-select traveler-filter-input">
                                <option value="">All locations in orbit</option>
                                @foreach (var location in Model.AvailableLocations)
                                {
                                    <option value="@location" selected="@(location == Model.SelectedLocation)">
                                        @location
                                    </option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="traveler-filter-checks">
                    <label class="host-toggle-card traveler-toggle-card">
                        <input asp-for="RequiresOxygen" class="form-check-input host-toggle-input" />
                        <span class="host-toggle-content">
                            <strong>Oxygen Ready Only</strong>
                            <span>Show only locations that actively supply breathable oxygen.</span>
                        </span>
                    </label>

                    <label class="host-toggle-card traveler-toggle-card">
                        <input asp-for="RequiresAlienPets" class="form-check-input host-toggle-input" />
                        <span class="host-toggle-content">
                            <strong>Alien Pets Welcome</strong>
                            <span>Filter for stays where companion spores, drakes, and orbitals are allowed.</span>
                        </span>
                    </label>

                    <label class="host-toggle-card traveler-toggle-card">
                        <input asp-for="RequiresSiliconSupport" class="form-check-input host-toggle-input" />
                        <span class="host-toggle-content">
                            <strong>Silicon-Safe Habitat</strong>
                            <span>Limit results to listings compatible with silicon lifeforms.</span>
                        </span>
                    </label>

                    <label class="host-toggle-card traveler-toggle-card">
                        <input asp-for="RequiresQuantumDock" class="form-check-input host-toggle-input" />
                        <span class="host-toggle-content">
                            <strong>Quantum Dock Access</strong>
                            <span>Show only listings with premium warp-side docking clearance.</span>
                        </span>
                    </label>
                </div>

                <div class="traveler-filter-actions">
                    <button type="submit" class="btn btn-primary">Search Listings</button>
                    @if (Model.HasActiveFilters)
                    {
                        <a class="btn btn-outline-light" asp-page="/Starports">Clear Filters</a>
                    }
                </div>
            </form>
        </div>

        <div class="traveler-panel-heading">
            <h2>Live Starship Listings</h2>
            <p>@Model.Listings.Count stay@(Model.Listings.Count == 1 ? "" : "s") now boarding</p>
        </div>

        @if (Model.Listings.Count == 0)
        {
            <div class="empty-state">
                @if (Model.HasActiveFilters)
                {
                    <p>No listings matched the current orbit filters. Try a broader search signal, a different location channel, or relax one of the habitat requirements.</p>
                }
                else
                {
                    <p>No live starship listings yet. Hosts will appear here the moment they launch a stay.</p>
                }
            </div>
        }
        else
        {
            <div class="traveler-listings">
                @foreach (var listing in Model.Listings)
                {
                    <article class="traveler-card">
                        <img src="@listing.PhotoUrl" alt="@listing.VesselName" class="traveler-card-image" />
                        <div class="traveler-card-body">
                            <div class="traveler-card-heading">
                                <div>
                                    <p class="starport-label">Open Orbit</p>
                                    <h3>@listing.VesselName</h3>
                                </div>
                                <strong class="traveler-price">@listing.NightlyRate.ToString("0.00") nebula credits/cycle</strong>
                            </div>

                            <p class="traveler-location">@listing.AlienLocation</p>

                            <div class="traveler-copy-block">
                                <p class="traveler-copy-label">Stay Summary</p>
                                <p class="traveler-summary">@listing.Summary</p>
                            </div>

                            <div class="traveler-spec-grid">
                                <div class="host-spec">
                                    <span>Atmosphere</span>
                                    <strong>@listing.AtmosphereProfile</strong>
                                </div>
                                <div class="host-spec">
                                    <span>Gravity</span>
                                    <strong>@listing.GravityProfile</strong>
                                </div>
                                <div class="host-spec">
                                    <span>Hosted By</span>
                                    <strong>@(listing.HostUser?.DisplayName ?? "Starstay Host")</strong>
                                </div>
                                <div class="host-spec">
                                    <span>Launch Date</span>
                                    <strong>@listing.CreatedUtc.ToLocalTime().ToString("MMM d, yyyy")</strong>
                                </div>
                            </div>

                            <div class="host-pill-grid">
                                <span class="host-pill @(listing.HasOxygen ? "host-pill-active" : "host-pill-muted")">
                                    @(listing.HasOxygen ? "Oxygen ready" : "Bring your own oxygen")
                                </span>
                                <span class="host-pill @(listing.SupportsSiliconLifeforms ? "host-pill-active" : "host-pill-muted")">
                                    @(listing.SupportsSiliconLifeforms ? "Silicon-safe habitat" : "Carbon-biased systems")
                                </span>
                                <span class="host-pill @(listing.AllowsAlienPets ? "host-pill-active" : "host-pill-muted")">
                                    @(listing.AllowsAlienPets ? "Alien pets welcome" : "No alien pets")
                                </span>
                                <span class="host-pill @(listing.HasQuantumDock ? "host-pill-active" : "host-pill-muted")">
                                    @(listing.HasQuantumDock ? "Quantum dock access" : "Standard docking")
                                </span>
                                <span class="host-pill @(listing.HasBioluminescentSpa ? "host-pill-active" : "host-pill-muted")">
                                    @(listing.HasBioluminescentSpa ? "Glow spa chamber" : "No spa chamber")
                                </span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(listing.AmenityNotes))
                            {
                                <p class="traveler-notes">
                                    <strong>Habitat notes:</strong> @listing.AmenityNotes
                                </p>
                            }

                            <div class="traveler-cta-row">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <a class="btn btn-primary" asp-page="/BookStarship" asp-route-id="@listing.Id">Book Voyage</a>
                                    <a class="btn btn-outline-light" asp-page="/AddStarship">Become A Host</a>
                                }
                                else
                                {
                                    <a class="btn btn-primary" asp-page="/Login" asp-route-returnUrl="@Url.Page("/BookStarship", new { id = listing.Id })">Login To Book</a>
                                    <a class="btn btn-outline-light" asp-page="/Register">Create Account</a>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</section>
